# Runtime switches
BLE_SCANNER_ENABLED=true
HTTP_SERVER_ENABLED=true
SKIP_MYSQL=false

# BLE scanner
BLE_INTERFACE=0
WATCHDOG_SECONDS=0
SENSOR_MACS=

# HTTP report server
HTTP_SERVER_HOST=0.0.0.0
HTTP_SERVER_PORT=8745
HTTP_REPORT_PATH=/daikin

# Forward sensor data to another endpoint
SENSOR_FORWARD_ENABLED=false
SENSOR_FORWARD_URL=

# Logging
LOG_LEVEL=INFO

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=change_me
MYSQL_DATABASE=mitemperature
MYSQL_CREATE_TABLE=true
